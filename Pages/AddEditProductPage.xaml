<Page x:Class="ZOO_magazin.Pages.AddEditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавление товара">

    <Grid Background="#F5F5F5">
        <Border Background="White" CornerRadius="10" BorderBrush="Black" BorderThickness="2"
                Width="600" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="Добавление товара" FontSize="28" FontWeight="Bold"
                           Foreground="Black" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Название -->
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
                        <TextBlock Text="Название товара" FontSize="16" Margin="0,0,0,5"/>
                        <TextBox Name="TextBoxName" Height="35" FontSize="14" Padding="5"/>
                    </StackPanel>

                    <!-- Артикул -->
                    <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,0,0,15">
                        <TextBlock Text="Артикул" FontSize="16" Margin="0,0,0,5"/>
                        <TextBox Name="TBart" Height="35" FontSize="14" Padding="5"/>
                    </StackPanel>

                    <!-- Описание -->
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,0,0,15">
                        <TextBlock Text="Описание" FontSize="16" Margin="0,0,0,5"/>
                        <TextBox Name="TextBoxDesc" Height="60" FontSize="14" Padding="5"
                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- Цена -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Цена (руб.)" FontSize="16" Margin="0,0,0,5"/>
                        <TextBox Name="TextBoxPrice" Height="35" FontSize="14" Padding="5"/>
                    </StackPanel>

                    <!-- Количество -->
                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Количество" FontSize="16" Margin="0,0,0,5"/>
                        <TextBox Name="TextBoxCount" Height="35" FontSize="14" Padding="5"/>
                    </StackPanel>

                    <!-- Единица измерения -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Единица измерения" FontSize="16" Margin="0,0,0,5"/>
                        <ComboBox Name="ComboUnit" Height="35" FontSize="14" Padding="5">
                            <ComboBoxItem Content="шт."/>
                            <ComboBoxItem Content="уп."/>
                            <ComboBoxItem Content="кг"/>
                            <ComboBoxItem Content="л"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Скидка -->
                    <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Скидка (%)" FontSize="16" Margin="0,0,0,5"/>
                        <TextBox Name="TextBoxDiscount" Height="35" FontSize="14" Padding="5" Text="0"/>
                    </StackPanel>

                    <!-- Кнопки -->
                    <StackPanel Grid.Row="5" Grid.ColumnSpan="3" 
                                Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Name="BtnSave" Content="Добавить" Width="120" Height="40"
                                Click="BtnSave_Click" Margin="0,0,20,0"
                                Background="Black" Foreground="White" FontSize="16"/>

                        <Button Name="BtnCancel" Content="Отмена" Width="120" Height="40"
                                Click="BtnCancel_Click"
                                Background="#999999" Foreground="White" FontSize="16"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Page>