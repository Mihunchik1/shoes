<Page x:Class="ZOO_magazin.Pages.АuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация">

    <Grid Background="Gray">
        <Border Background="White" CornerRadius="10" Width="400" Padding="30"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Авторизация" FontSize="32" FontWeight="Bold"
                           Foreground="black" HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Text="Логин" FontSize="20" />
                <TextBox Name="TBoxLogin" Height="40" Margin="0,0,0,15"
                         FontSize="16" Padding="10"/>
                <TextBlock Text="Пароль" FontSize="20"/>
                <PasswordBox Name="PboxPassword" Height="40" Margin="0,0,0,30"
                             FontSize="16" Padding="10"/>

                <StackPanel>
                    <Button Name="BtnLogin" Content="Войти" Height="40"
                            Click="BtnLogin_Click" FontSize="16"
                            Background="Black" Foreground="White"
                            Margin="0,0,0,10"/>

                    <Button Name="BtnGuest" Content="Войти как гость" 
                            Click="BtnGuest_Click" Height="35"
                            FontSize="14" Background="Gray" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>