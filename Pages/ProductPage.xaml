<Page x:Class="ZOO_magazin.Pages.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог товаров" Loaded="Page_Loaded">

    <Grid Background="#F0F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="737*"/>
            <ColumnDefinition Width="74*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Background="Gray" Grid.ColumnSpan="2" Margin="0,0,0.2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Image Source="/Resources/Icon.png" Grid.Column="0" HorizontalAlignment="Left" Width="60"/>

            <TextBlock Grid.Column="1" Text="Магазин Обуви" 
                       FontFamily="Times New Roman" FontSize="28" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center" 
                       HorizontalAlignment="Center" Margin="20,0,0,0"/>

            <TextBlock Grid.Column="2" x:Name="UserInfoLabel" Foreground="White" 
                       FontFamily="Segoe UI" FontSize="14" VerticalAlignment="Center"
                       HorizontalAlignment="Right" Margin="0,0,20,0"/>
        </Grid>

        <!-- Панель поиска и фильтров -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" 
                Margin="20,10,20.2,10" Padding="15" Grid.ColumnSpan="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <!-- Поиск -->
                <TextBlock Text="Поиск:" VerticalAlignment="Center" 
                           Margin="0,0,10,0" FontFamily="Segoe UI" FontSize="14"/>
                <TextBox Name="TBoxSearch" Width="250" Height="30"
                         TextChanged="TBoxSearch_TextChanged"
                         VerticalAlignment="Center" Padding="5"/>

                <!-- Сортировка по цене -->
                <ComboBox Name="ComboSortBy" Width="200" Height="30" Margin="20,0,0,0"
                          VerticalAlignment="Center" FontSize="14"
                          SelectionChanged="ComboSortBy_SelectionChanged">
                    <ComboBoxItem Content="Сортировка"/>
                    <ComboBoxItem Content="По возрастанию цены"/>
                    <ComboBoxItem Content="По убыванию цены"/>
                </ComboBox>

                <!-- Фильтр по количеству -->
                <ComboBox Name="ComboSort" Width="200" Height="30" Margin="20,0,0,0"
                          VerticalAlignment="Center" FontSize="14"
                          SelectionChanged="ComboSort_SelectionChanged">
                    <ComboBoxItem Content="Все товары"/>
                    <ComboBoxItem Content="Менее 10 шт"/>
                    <ComboBoxItem Content="10-50 шт"/>
                    <ComboBoxItem Content="Более 50 шт"/>
                </ComboBox>

            </StackPanel>
        </Border>

        <!-- Список товаров -->
        <ListView Grid.Row="2" Name="LviewProduct" Margin="20,0,20.2,20.2"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.ColumnSpan="2">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="10" Padding="15" Margin="0,0,0,10"
                            Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- Картинка -->
                            <Image Grid.Column="0" Height="150" Width="180"
                                   Source="{Binding Tag}" Stretch="Uniform"/>

                            <!-- Информация -->
                            <StackPanel Width="1000" Grid.Column="1" Margin="20,0,20,0">
                                <TextBlock FontSize="20" FontWeight="Bold"
                                           Text="{Binding Name}" Margin="0,0,0,10"
                                           Foreground="Black"/>

                                <TextBlock FontSize="14" Margin="0,0,0,5">
                                    <Run Text="Артикул: "/>
                                    <Run Text="{Binding Articul}" FontWeight="Bold"/>
                                </TextBlock>

                                <TextBlock FontSize="14" TextWrapping="Wrap"
                                           Text="{Binding Discription}" Margin="0,0,0,10"
                                           Foreground="#666666" MaxHeight="60"/>

                                <TextBlock FontSize="14">
                                    <Run Text="На складе: "/>
                                    <Run Text="{Binding CountSklad}" FontWeight="Bold"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding Unit}"/>
                                </TextBlock>

                                <!-- Производитель и категория -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock FontSize="12" Foreground="#888888">
                                        <Run Text="Производитель: "/>
                                        <Run Text="{Binding Manufacturer.NameManufacturer}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock FontSize="24" FontWeight="Bold"
                                           Foreground="Gray" HorizontalAlignment="Center"
                                           Margin="0,0,0,20">
                                    <Run Text="{Binding Price, StringFormat={}{0:N2} руб.}"/>
                                </TextBlock>

                                <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" 
                                            HorizontalAlignment="Center">
                                    <Button Content="✏️ Редактировать" Name="BtnEdit" 
                                            Click="Edit_Click" Margin="5" Padding="10,5"
                                            FontSize="11" Background="Gray" 
                                            Foreground="White" Width="120"/>

                                    <Button Content="🗑️ Удалить" Name="BtnDelete" 
                                            Click="Delete_Click" Margin="5" Padding="10,5"
                                            FontSize="11" Background="#F44336" 
                                            Foreground="White" Width="100"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="3" Background="Gray" Grid.ColumnSpan="2" Margin="0,0.8,0.2,-0.8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Name="BtnOrder" Content="Заказы" 
                    HorizontalAlignment="Left" Margin="20,0,20,0" Width="120" Height="35"
                    FontSize="14" Background="Black" Foreground="White"/>
            <Button Grid.Column="1" Name="BtnAdd" Content="Добавить товар" 
                    HorizontalAlignment="Right"  Margin="20,0,20,0" Width="150" Height="35"
                    FontSize="14" Background="Black" Foreground="White"
                    Click="BtnAdd_Click"/>



        </Grid>
    </Grid>
</Page>